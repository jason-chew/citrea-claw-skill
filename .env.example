# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then paste the token it gives you
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram chat ID
# Easiest way to find it: open Telegram, search @userinfobot, send /start
# It will instantly reply with your numeric ID
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Arb Alert Settings ───────────────────────────────────────────────────────
# Minimum net profit (after fees) to trigger a Telegram alert, in basis points
# 50 = 0.5%, 100 = 1.0%, 25 = 0.25%
# Lower = more alerts, higher = only the juicy ones
ARB_ALERT_THRESHOLD_BPS=50

# How often to scan for arb opportunities, in seconds
# Default is 30 — don't go below 5 or you'll hammer the RPC
ARB_MONITOR_INTERVAL_SEC=30

# How long to wait before re-alerting on the same arb pair in minutes (default 30)
ARB_DEBOUNCE_MIN=30
